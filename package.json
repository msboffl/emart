    "generate:tree": "struct -i '**/*.*' -i '**/public' -i '**/src' -i '**/app' -i '**/specs' -i '**/assets' -i .github -i .nx -i .vscode -i .next -i dist -o project.tree",
    "prettier:format": "prettier --write .",
    "prettier:check": "prettier --check .",
    "admin:dev": "pnpm --filter admin dev",
    "admin:build": "pnpm --filter admin build",
    "admin:preview": "pnpm --filter admin preview",
    "admin:lint": "pnpm --filter admin lint",
    "web:dev": "pnpm --filter web dev",
    "web:build": "pnpm --filter web build",
    "web:lint": "pnpm --filter web lint"
  },
  "keywords": [
    "emart"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msboffl/emart.git"
  },
  "bugs": {
    "url": "https://github.com/msboffl/emart/issues"
  },
